  "skill": {
    "name": "奇兵詭出",
    "description": {
      "0": "尋覓敵人的破綻，切換至<tooltip ns=tooltips_gen baseKey18=11290001 values=[]><strong>奇謀</strong></tooltip>狀態。在這種狀態下：",
