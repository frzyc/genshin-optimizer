  "passive2": {
    "name": "戲言的傑作",
    "description": {
      "0": "在<tooltip ns=tooltips_gen baseKey18=11290001 values=[]><strong>奇謀</strong></tooltip>狀態下，隊伍中附近的其他角色對敵人觸發<cryo>冰元素相關反應</cryo>後的8秒內，該角色的攻擊力提升15%，洛恩的攻擊力提升15%。"
    }
  },
  "passive3": {
    "name": "興盡且去來",
    "description": {
      "0": "施放元素戰技<strong>奇兵詭出</strong>後，洛恩還會獲得9秒的「乘興」效果：持續期間，元素戰技<strong>奇兵詭出</strong>的技能等級提高1級。",
      "1": "施放元素戰技時，如果隊伍中其他角色的普通攻擊、元素戰技或元素爆發中，任一技能等級不低於洛恩的元素戰技的技能等級，則本次「乘興」效果的持續時間額外延長6秒。",
      "2": "每18秒至多獲得一次「乘興」效果。"
    }
  },
  "lockedPassive": {
    "name": "魔女的前夜禮·不癒之刺",
    "description": {
      "0": "完成<strong>魔女的課業·諸敵之題</strong>後，洛恩將成為<strong>魔導</strong>角色。隊伍中編入至少2名魔導角色時，將獲得<strong>魔導·秘儀</strong>效果，使魔導角色獲得強化。",
      "1": "<br/>",
      "2": "<strong>魔導·秘儀</strong>",
      "3": "特殊元素戰技<tooltip ns=tooltips_gen baseKey18=11290002 values=[]><strong>鏤骨徹心</strong></tooltip>命中敵人或施放元素爆發<strong>裁罰遂成</strong>時，若<tooltip ns=tooltips_gen baseKey18=11290004 values=[]><strong>爭勝</strong></tooltip>至少為上限的50%，則洛恩的普通攻擊與重擊造成的傷害提升40%，持續6秒。"
    }
  },
