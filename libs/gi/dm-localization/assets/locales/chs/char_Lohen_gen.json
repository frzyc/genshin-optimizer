  "skill": {
    "name": "奇兵诡出",
    "description": {
      "0": "寻觅敌人的破绽，切换至<tooltip ns=tooltips_gen baseKey18=11290001 values=[]><strong>奇谋</strong></tooltip>状态。在这种状态下：",
      "1": [
