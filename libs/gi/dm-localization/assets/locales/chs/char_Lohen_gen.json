  "passive3": {
    "name": "兴尽且去来",
    "description": {
      "0": "施放元素战技<strong>奇兵诡出</strong>后，洛恩还会获得9秒的「乘兴」效果：持续期间，元素战技<strong>奇兵诡出</strong>的技能等级提高1级。",
      "1": "施放元素战技时，如果队伍中其他角色的普通攻击、元素战技或元素爆发中，任一技能等级不低于洛恩的元素战技的技能等级，则本次「乘兴」效果的持续时间额外延长6秒。",
      "2": "每18秒至多获得一次「乘兴」效果。"
    }
  },
  "lockedPassive": {
    "name": "魔女的前夜礼·不愈之刺",
    "description": {
      "0": "完成<strong>魔女的课业·诸敌之题</strong>后，洛恩将成为<strong>魔导</strong>角色。队伍中编入至少2名魔导角色时，将获得<strong>魔导·秘仪</strong>效果，使魔导角色获得强化。",
